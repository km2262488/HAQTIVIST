# Compile
go build -o hulk hulk.go

# Basic usage (test own server!)
./hulk -site http://localhost:8080 -threads 50 -duration 30

# With POST data
./hulk -site http://localhost:8080/api -method POST -data "key=value" -threads 100

# With custom User-Agents file
./hulk -site http://localhost:8080 -agents useragents.txt -threads 200

# Verbose mode for debugging
./hulk -site http://localhost:8080 -verbose -threads 50 -duration 60
